# Supabase → Project Settings → Database → Connection string
# DATABASE_URL: tab "Transaction pooler" (port 6543) — dùng lúc app chạy
DATABASE_URL="postgresql://postgres:[PASSWORD]@[HOST]:6543/postgres?pgbouncer=true"
# DIRECT_URL: tab "Direct connection" (port 5432) — chỉ dùng khi chạy migrate/db push
DIRECT_URL="postgresql://postgres:[PASSWORD]@[HOST]:5432/postgres"

# Google Cloud Console → APIs & Services → Credentials → OAuth 2.0 Client ID
# Authorized redirect URI: http://localhost:3000/api/auth/callback/google (dev)
#                           https://<domain-cua-ban>/api/auth/callback/google (prod)
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="" # tạo bằng lệnh: openssl rand -base64 32

# Supabase → Project Settings → API → Project URL & anon public key
# Dùng cho upload file trong tab "Tài nguyên" (Storage → tạo bucket "resources", đặt Public)
NEXT_PUBLIC_SUPABASE_URL=""
NEXT_PUBLIC_SUPABASE_ANON_KEY=""

# Resend (resend.com) → dùng để gửi email OTP ký hợp đồng. Không điền thì bỏ qua tính năng này.
RESEND_API_KEY=""
