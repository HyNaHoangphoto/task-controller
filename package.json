{
  "name": "task-controller",
  "version": "2.0.0",
  "private": true,
  "description": "Freelancer OS — quản lý dự án, hoá đơn, khách hàng & CTV trong một workspace.",
  "author": "Task Controller <hoangkhoinhiepanh@gmail.com>",
  "main": "electron/main.js",
  "scripts": {
    "dev": "next dev",
   "build": "prisma generate && next build",
    "start": "next start",
    "lint": "next lint",
    "db:push": "prisma db push",
    "db:seed": "tsx prisma/seed.ts",
    "db:studio": "prisma studio",
    "electron": "electron .",
    "dist": "electron-builder --win nsis"
  },
  "build": {
    "appId": "com.hoangkhoinhiepanh.taskcontroller",
    "productName": "Task Controller",
    "files": [
      "electron/**/*"
    ],
    "win": {
      "icon": "build/icon.png",
      "target": "nsis"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true
    }
  },
  "dependencies": {
    "@next-auth/prisma-adapter": "^1.0.7",
    "@prisma/client": "^5.20.0",
    "@react-pdf/renderer": "^4.5.1",
    "@supabase/supabase-js": "^2.110.0",
    "clsx": "^2.1.1",
    "date-fns": "^3.6.0",
    "googleapis": "^144.0.0",
    "lucide-react": "^0.453.0",
    "next": "14.2.5",
    "next-auth": "^4.24.14",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "recharts": "^2.12.7",
    "resend": "^6.12.3",
    "tailwind-merge": "^2.5.2",
    "zustand": "^4.5.5"
  },
  "devDependencies": {
    "@types/node": "^20",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "autoprefixer": "^10.4.20",
    "electron": "^31.3.0",
    "electron-builder": "^24.13.3",
    "postcss": "^8.4.47",
    "prisma": "^5.20.0",
    "tailwindcss": "^3.4.13",
    "tsx": "^4.19.1",
    "typescript": "^5"
  }
}
